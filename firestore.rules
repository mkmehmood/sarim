rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function notSuspended() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('approved', true) != false;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin' &&
        notSuspended();
    }

    // Top-level user document — stores role, approved, forceLogout
    // Each user reads their own on startup to check if suspended
    // Admin can read/write any user doc to suspend, reinstate, remove
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // All subcollections under a user document
    // Owner: full access to own data (all collections: devices, settings, sales, etc.)
    // Admin: read/write devices (remote control) and settings (accounts_index, team)
    match /users/{uid}/{subcollection}/{docId} {
      allow read, write: if isOwner(uid) && notSuspended();
      allow read, write: if isAdmin() && subcollection in ['devices', 'settings'];
    }

    // Deeply nested subcollections
    match /users/{uid}/{subcollection}/{docId}/{rest=**} {
      allow read, write: if isOwner(uid) && notSuspended();
      allow read, write: if isAdmin() && subcollection in ['devices', 'settings'];
    }

  }
}
